# Flask Configuration
SECRET_KEY=mirletter-secret-key-12345
DATABASE_URL=sqlite:///mirletter.db

# Session cookies: laisser tel quel en local (HTTP). En production derrière HTTPS,
# passer les deux à True/None pour permettre l'embed des iframes de souscription cross-site.
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=False

# Security: Key for encrypting SMTP passwords (32-byte base64 string)
ENCRYPTION_KEY=36lFeN6BodRNJLR-n3ZPQwzU1Zw4c55pPPzpGk5iaOw=

# Mail Server (System notifications)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-password

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Telegram bot (créé via @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# Nom d'utilisateur du bot (sans @), utilisé pour afficher le lien de liaison
TELEGRAM_BOT_USERNAME=VotreBot

# Mistral AI (génération de contenu HTML)
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_MODEL=mistral-large-latest

# URL publique du site, utilisée par le bot Telegram pour générer les liens de prévisualisation
SITE_BASE_URL=http://127.0.0.1:9060
